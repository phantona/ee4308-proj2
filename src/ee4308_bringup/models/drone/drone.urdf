            </geometry>
        </collision>
        <visual name="rotor_2_visual">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://ee4308_bringup/models/drone/meshes/propeller_ccw.dae" 
                    scale="0.1 0.1 0.1"/>
            </geometry>
            <material name="blue" />
        </visual>
    </link>
    <joint name="rotor_2_joint" type="continuous">
        <parent link="base_link"/>
