                        <scale>0.01 0.01 0.01</scale>
                        <uri>model://drone/meshes/spotlight.dae</uri>
                    </mesh>
                </geometry>
            </visual> -->
        <visual name="marker_visual_2">
            <origin xyz="-0.08 0.037 0.04" rpy="-1.0472 -0 0.2" />
            <geometry>
                <mesh filename="package://ee4308_bringup/models/drone/meshes/led.dae" 
                    scale="1 1 1"/>
            </geometry>
        </visual>
        <!-- <visual name="right_flashlight_visual">
                <pose frame="">-0.061985 -0.060826 0.046102 0.06 -4.8e-05 -1.87</pose>
                <geometry>
                    <mesh>
                        <scale>0.01 0.01 0.01</scale>
                        <uri>model://drone/meshes/spotlight.dae</uri>
                    </mesh>
                </geometry>
            </visual> -->
        <visual name="marker_visual_3">
            <origin xyz="-0.08 0.035 0.04" rpy="1.0472 -0 -0.1" />
            <geometry>
                <mesh filename="package://ee4308_bringup/models/drone/meshes/led.dae" 
                    scale="1 1 1"/>
            </geometry>
        </visual>

        <visual name="camera_visual">
            <origin xyz="0.1 0 0" rpy="0 0 0" />
            <geometry>
                <box size="0.02 0.02 0.02"/>
            </geometry>
        </visual>
    </link>
    <link name="rotor_0">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="0.005" />
            <inertia ixx="9.75e-07"
                     ixy="0"
                     ixz="0"
                     iyy="4.17041e-05"
                     iyz="0"
                     izz="4.26041e-05" />
        </inertial>
        <collision name="rotor_0_collision">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <cylinder length="0.005" radius="0.1" />
            </geometry>
        </collision>
        <visual name="rotor_0_visual">
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://ee4308_bringup/models/drone/meshes/propeller_ccw.dae" 
                    scale="0.1 0.1 0.1"/>
            </geometry>
            <material name="blue" />
        </visual>
    </link>
    <joint name="rotor_0_joint" type="continuous">
        <parent link="base_link"/>
        <child link="rotor_0"/>
        <origin xyz="0.13 -0.22 0.023" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>
    <link name="rotor_1">
        <inertial>
