            </geometry>
            <material name="red" />
        </visual>
    </link>
    <joint name="rotor_1_joint" type="continuous">
        <parent link="base_link"/>
        <child link="rotor_1"/>
        <origin xyz="-0.13 0.2 0.023" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>
    <link name="rotor_2">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <mass value="0.005" />
            <inertia ixx="9.75e-07"
                     ixy="0"
                     ixz="0"
                     iyy="4.17041e-05"
                     iyz="0"
                     izz="4.26041e-05" />
        </inertial>
        <collision name="rotor_2_collision">
